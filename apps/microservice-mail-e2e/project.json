{
  "name": "microservice-mail-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": [
    "microservice-mail"
  ],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{e2eProjectRoot}"
      ],
      "options": {
        "jestConfig": "apps/microservice-mail-e2e/jest.config.ts",
        "passWithNoTests": true
      },
      "dependsOn": [
        "microservice-mail:build",
        "microservice-mail:serve"
      ]
    }
  }
}
